{
  "name": "lingce",
  "version": "1.0.0",
  "private": true,
  "description": "灵测 LingCe — AI 驱动的 YAPI 接口智能测试平台",
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix server install && npm --prefix web install && npm --prefix xmind-mcp install",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "start": "npm --prefix server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
