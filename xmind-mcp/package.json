{
  "name": "cursor-xmind-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "MCP server for creating and opening XMind mind maps from Cursor.",
  "type": "module",
  "bin": {
    "cursor-xmind-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jszip": "^3.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
