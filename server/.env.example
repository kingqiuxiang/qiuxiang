# 后端端口
PORT=4178

# 允许的前端来源（CORS），逗号分隔，缺省允许全部
CORS_ORIGIN=

# ===== AI（兼容 OpenAI 协议）=====
# 未配置 AI_API_KEY 时，将自动降级为本地启发式引擎（离线可用）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ===== YAPI（可在 UI 设置中覆盖）=====
YAPI_BASE_URL=
YAPI_TOKEN=

# ===== 被测项目（可在 UI 设置中覆盖）=====
# 项目根目录，用于代码扫描与启动
PROJECT_PATH=
# 启动命令，如：npm run dev
PROJECT_START_CMD=
# 开发环境后端基址，发请求时拼接接口 path
DEV_API_BASE_URL=
# 开发环境前端页面地址，用于前端页面测试
DEV_WEB_URL=
