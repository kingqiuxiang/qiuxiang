# APIPilot backend configuration (all optional - the app ships with safe demo fallbacks)

# Server
PORT=8787

# YAPI integration
YAPI_BASE_URL=https://yapi.your-company.com
YAPI_TOKEN=your_project_token
YAPI_PROJECT_ID=

# AI provider (OpenAI compatible: OpenAI, DeepSeek, Moonshot, Qwen, local Ollama, ...)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Target project under test
PROJECT_ROOT=/path/to/your/project
PROJECT_START_COMMAND=npm run dev
PROJECT_HEALTH_URL=http://localhost:3000

# Dev environment endpoints
DEV_API_BASE_URL=http://localhost:3000
DEV_WEB_BASE_URL=http://localhost:5173
