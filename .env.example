# ===== 灵测 LingCe 环境变量示例 =====
# 复制为 .env 后按需填写。所有配置也可以在「项目设置」页面中可视化填写。

# 后端服务端口
PORT=8787

# ---- 默认 AI 配置（OpenAI 兼容接口）----
# 支持 OpenAI / DeepSeek / 通义千问 / Moonshot 等任何兼容 /v1/chat/completions 的服务
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---- 默认 YAPI 配置 ----
YAPI_BASE_URL=
YAPI_TOKEN=

# 当未配置 AI / YAPI 时，平台会自动进入「演示模式」并使用内置 Mock 数据。
