# ===== 服务端口 =====
PORT=8787

# ===== YAPI 配置 =====
# YAPI 站点地址，例如 http://yapi.company.com
YAPI_BASE_URL=
# YAPI 项目 token（项目设置 -> token 配置）
YAPI_TOKEN=
# 可选：直接指定 YAPI 项目 ID
YAPI_PROJECT_ID=

# ===== AI 配置（OpenAI 兼容接口）=====
# 留空则使用内置启发式参数生成（无需联网）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ===== 被测项目 =====
# 项目源码根目录（用于 AI 读取代码作为参数填充基准）
PROJECT_ROOT=
# 开发环境后端地址（接口测试目标）
DEV_API_BASE_URL=http://localhost:3000
# 开发环境前端地址（页面测试目标）
DEV_WEB_BASE_URL=http://localhost:5173
# AI 一键启动项目的命令（在 PROJECT_ROOT 下执行），例如 "npm run dev"
PROJECT_START_COMMAND=
