{
  "name": "xmind-mcp-server",
  "version": "1.0.0",
  "description": "A Cursor MCP server that creates XMind mind maps and opens them locally on Windows.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xmind-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "cursor",
    "xmind",
    "mindmap"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jszip": "^3.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
