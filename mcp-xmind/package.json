{
  "name": "mcp-xmind",
  "version": "1.0.0",
  "private": true,
  "description": "MCP 服务：让 Cursor 直接根据需求生成 XMind 思维导图(.xmind)，并自动用本地 XMind 打开（支持 Windows / macOS / Linux）",
  "type": "module",
  "bin": {
    "mcp-xmind": "src/index.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "jszip": "^3.10.1",
    "zod": "^3.23.8"
  }
}
