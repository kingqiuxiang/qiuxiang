{
  "name": "mcp-xmind",
  "version": "1.0.0",
  "description": "Local MCP server for creating and opening XMind mind maps from Cursor.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xmind-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --import tsx --test test/xmind.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "xmind",
    "cursor",
    "mindmap"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jszip": "^3.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
